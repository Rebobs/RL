{
    "communication": {
        "control_port": 5555,
        "metrics_port": 5556,
        "control_address": "tcp://127.0.0.1:5555",
        "metrics_address": "tcp://127.0.0.1:5556"
    },
    "control_format": {
        "gain": {
            "type": "float",
            "min": 0.0,
            "max": 10.0,
            "default": 1.0
        },
        "phase": {
            "type": "float",
            "min": -0.02,
            "max": 0.02,
            "default": 0.0
        },
        "eq_mu": {
            "type": "float",
            "min": 0.0,
            "max": 0.01,
            "default": 0.001
        }
    },
    "metrics_format": {
        "snr": {
            "type": "float",
            "description": "SNR v dB"
        },
        "power": {
            "type": "float",
            "description": "Výkon signálu"
        },
        "cfo": {
            "type": "float",
            "description": "Carrier frequency offset"
        },
        "throughput": {
            "type": "float",
            "description": "Throughput v Mbps"
        },
        "rtt": {
            "type": "float",
            "description": "RTT v ms"
        },
        "loss": {
            "type": "float",
            "description": "Packet loss v percentách"
        },
        "bler": {
            "type": "float",
            "description": "BLER (Block Error Rate)"
        },
        "detached": {
            "type": "bool",
            "description": "UE detach stav"
        }
    },
    "reward_formula": "1.5 * throughput - 15 * loss - 0.05 * rtt - 5.0 * bler",
    "runtime": {
        "control_period_ms": 200,
        "save_interval_seconds": 300
    }
}
