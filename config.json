{
    "communication": {
        "control_address": "tcp://127.0.0.1:5555",
        "metrics_address": "tcp://127.0.0.1:5556"
    },
    "debug": {
        "enabled": true,
        "rl_decisions_log": true,
        "metrics_log": true
    },
    "monitor": {
        "enabled": true,
        "window": 1000,
        "update_interval_ms": 100
